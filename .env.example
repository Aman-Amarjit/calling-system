# Telnyx
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=

# Deepgram
DEEPGRAM_API_KEY=

# Groq
GROQ_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ngrok static domain (required at runtime, not checked on startup)
NGROK_URL=https://your-static-domain.ngrok-free.app

# LLM backend — leave GROQ_API_KEY blank to use local Ollama instead
# Ollama (local, free) — install from https://ollama.com, then: ollama pull llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
